{
    "comments": {
		"lineComment": {
			"comment": "#"
		},
    },
    "brackets": [
		["{", "}"],
		["{", "}"],
		["[", "]"],
		["(", ")"]
    ],
    "autoClosingPairs": [
		{ "open": "{", "close": "}" },
		{ "open": "^{", "close": "}" },
		{ "open": "[", "close": "]" },
		{ "open": "(", "close": ")" },
		{ "open": "\"", "close": "\"", "notIn": ["string", "comment"] }
    ],
    "surroundingPairs": [
		["{", "}"],
		["[", "]"],
		["(", ")"],
		["\"", "\""]
    ],
    "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*|[0-9]+",
    "indentationRules": {
		"increaseIndentPattern": "([{[(]|\\^{\\s*([a-zA-Z_][a-zA-Z0-9_]*))\\s*$",
		"decreaseIndentPattern": "^\\s*[\\}\\]\\)]"
    },
}
