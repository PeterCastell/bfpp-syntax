{
    "scopeName": "markdown.bfpp.codeblock",
    "injectionSelector": "L:text.html.markdown",
    "patterns": [
        {
            "begin": "(^|\\G)(\\s*)(```)\\s*(bfpp)\\s*$",
            "end": "(^|\\G)(\\s*)(```)\\s*$",
            "contentName": "markup.fenced_code.block.markdown meta.embedded.block.bfpp",
            "beginCaptures": {
                "3": { "name": "punctuation.definition.markdown" },
                "4": { "name": "fenced_code.block.language.markdown" }
            },
            "endCaptures": {
                "3": { "name": "punctuation.definition.markdown" }
            },
            "patterns": [
                { "include": "source.bfpp" }
            ]
        }
    ]
}